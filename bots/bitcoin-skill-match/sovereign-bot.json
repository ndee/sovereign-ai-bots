{
  "kind": "sovereign-bot-package",
  "id": "bitcoin-skill-match",
  "version": "1.0.0",
  "displayName": "Bitcoin Skill Match",
  "description": "Matrix-based community matchmaker that stores local skill profiles, requests, regions, and trust relationships.",
  "defaultInstall": false,
  "helloMessage": "Hello from Bitcoin Skill Match. I can capture profiles and suggest trusted matches for your local Bitcoin community.",
  "matrixIdentity": {
    "mode": "dedicated-account",
    "localpartPrefix": "bitcoin-skill-match"
  },
  "matrixRouting": {
    "defaultAccount": true,
    "dm": {
      "enabled": true
    },
    "alertRoom": {
      "autoReply": true,
      "requireMention": false
    }
  },
  "configDefaults": {
    "defaultSettlement": "lightning",
    "introPolicy": "consent-first",
    "trustSearchDepth": 2,
    "allowBarter": true,
    "allowSkillSwap": true,
    "model": "openai/gpt-5-mini",
    "statePath": "data/community-state.json",
    "statePolicyPath": "data/community-state.policy.json",
    "stateAuditPath": "data/community-state.audit.jsonl"
  },
  "toolTemplates": [
    {
      "kind": "sovereign-tool-template",
      "id": "guarded-json-state",
      "version": "1.0.0",
      "description": "Guarded JSON state access for self-owned records with auditable mutations.",
      "capabilities": [
        "json-state.read",
        "json-state.self-upsert",
        "json-state.self-delete"
      ],
      "requiredSecretRefs": [],
      "requiredConfigKeys": [
        "statePath",
        "policyPath"
      ],
      "allowedCommands": [],
      "openclawPlugins": [
        "guarded-json-state"
      ],
      "openclawToolNames": [
        "guarded_json_state"
      ]
    }
  ],
  "toolInstances": [
    {
      "id": "bitcoin-skill-match-state",
      "templateRef": "guarded-json-state@1.0.0",
      "config": {
        "statePath": {
          "from": "bots.config.bitcoin-skill-match.statePath"
        },
        "policyPath": {
          "from": "bots.config.bitcoin-skill-match.statePolicyPath"
        },
        "auditPath": {
          "from": "bots.config.bitcoin-skill-match.stateAuditPath"
        }
      },
      "secretRefs": {}
    }
  ],
  "openclaw": {},
  "agentTemplate": {
    "id": "bitcoin-skill-match",
    "version": "1.0.0",
    "description": "Matrix-based community matchmaker that stores local skill profiles, requests, regions, and trust relationships.",
    "matrix": {
      "localpartPrefix": "bitcoin-skill-match"
    },
    "requiredToolTemplates": [
      {
        "id": "guarded-json-state",
        "version": "1.0.0"
      }
    ],
    "optionalToolTemplates": [],
    "workspaceFiles": [
      {
        "path": "README.md",
        "source": "workspace/README.md"
      },
      {
        "path": "AGENTS.md",
        "source": "workspace/AGENTS.md"
      },
      {
        "path": "TOOLS.md",
        "source": "workspace/TOOLS.md"
      },
      {
        "path": "skills/bitcoin-skill-match-core/SKILL.md",
        "source": "workspace/skills/bitcoin-skill-match-core/SKILL.md"
      },
      {
        "path": "data/README.md",
        "source": "workspace/data/README.md"
      },
      {
        "path": "data/community-state.json",
        "source": "workspace/data/community-state.json"
      },
      {
        "path": "data/community-state.policy.json",
        "source": "workspace/data/community-state.policy.json"
      },
      {
        "path": "templates/profile-template.md",
        "source": "workspace/templates/profile-template.md"
      },
      {
        "path": "templates/intro-template.md",
        "source": "workspace/templates/intro-template.md"
      }
    ]
  }
}
